@startuml
title Sequence Diagram — Создание заказа и назначение задачи

actor User as user
participant "API Gateway" as gateway
participant "Order Service" as order
participant "Robot Service" as robot
participant "Task Service" as task
participant "Kafka" as kafka
database "PostgreSQL" as db

user -> gateway: POST /orders
activate gateway

gateway -> order: CreateOrder
activate order

order -> db: INSERT orders
activate db
db --> order: OK
deactivate db

order -> kafka: publish OrderCreated
activate kafka
kafka --> order: Ack
deactivate kafka

order --> gateway: Order created
deactivate order

gateway -> robot: AssignRobot
activate robot

robot -> db: SELECT robots WHERE status='idle'
activate db
db --> robot: [robot list]
deactivate db

robot -> task: CreateTask
activate task

task -> db: INSERT tasks
activate db
db --> task: OK
deactivate db

task -> kafka: publish TaskAssigned
activate kafka
kafka --> task: Ack
deactivate kafka

task --> robot: Task created
deactivate task

robot --> gateway: Robot assigned
deactivate robot

gateway --> user: 201 Created
deactivate gateway

@enduml