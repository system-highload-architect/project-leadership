@startuml
title State Diagram — Жизненный цикл заказа

[*] --> CREATED : Создан
CREATED --> IN_PROGRESS : Назначена задача
IN_PROGRESS --> COMPLETED : Все задачи выполнены
IN_PROGRESS --> CANCELLED : Отменён пользователем
CREATED --> CANCELLED : Отменён до начала
COMPLETED --> [*]
CANCELLED --> [*]

@enduml