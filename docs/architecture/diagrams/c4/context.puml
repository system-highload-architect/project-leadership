@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()
title System Context Diagram — Order Management System

Person(customer, "Customer", "Покупатель, который размещает заказы")
Person(admin, "Admin", "Администратор, управляющий продуктами и заказами")

System(oms, "Order Management System", "Управляет заказами, платежами и уведомлениями")

System_Ext(payment_gateway, "Payment Gateway", "Внешняя система для обработки платежей")
System_Ext(notification_service, "Notification Service", "Внешняя система для отправки уведомлений")

Rel(customer, oms, "Размещает заказы", "HTTPS")
Rel(admin, oms, "Управляет продуктами", "HTTPS")
Rel(oms, payment_gateway, "Обрабатывает платежи", "HTTPS")
Rel(oms, notification_service, "Отправляет уведомления", "SMTP/HTTP")
@enduml