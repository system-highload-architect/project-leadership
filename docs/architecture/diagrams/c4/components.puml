@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()
title Component Diagram — Order Service

Container(order_service, "Order Service", "Go", "Управление заказами")

Component(controller, "Order Controller", "Gin", "Обрабатывает HTTP-запросы")
Component(usecase, "Order Use Cases", "Go", "Бизнес-логика заказов")
Component(domain, "Domain", "Go", "Сущности и правила")
Component(repo_interface, "Repository Interface", "Go", "Интерфейс доступа к данным")
Component(repo_impl, "Postgres Repository", "Go + pgx", "Реализация репозитория")
Component(kafka_adapter, "Kafka Adapter", "Go + Sarama", "Публикация событий")

Rel(controller, usecase, "Вызывает")
Rel(usecase, domain, "Использует")
Rel(usecase, repo_interface, "Вызывает")
Rel(repo_impl, repo_interface, "Реализует")
Rel(usecase, kafka_adapter, "Публикует события")
@enduml