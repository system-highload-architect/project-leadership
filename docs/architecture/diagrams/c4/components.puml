@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Component Diagram — Robot Service

Container(robot_service, "Robot Service", "Go", "Управление роботами")

Component(handler, "HTTP Handler", "Gin", "Принимает запросы")
Component(usecase, "Use Cases", "Go", "Бизнес-логика")
Component(domain, "Domain", "Go", "Сущности и правила")
Component(repo, "Repository", "Go", "Интерфейс доступа к данным")
Component(postgres_adapter, "Postgres Adapter", "Go + pgx", "Реализация репозитория")
Component(kafka_adapter, "Kafka Adapter", "Go + Sarama", "Публикация событий")

Rel(handler, usecase, "Вызывает", "зависит")
Rel(usecase, domain, "Использует", "зависит")
Rel(usecase, repo, "Вызывает", "зависит")
Rel(postgres_adapter, repo, "Реализует", "реализует интерфейс")
Rel(kafka_adapter, usecase, "Реализует", "реализует интерфейс")

@enduml