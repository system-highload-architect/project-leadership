@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container Diagram — Order Management System

Person(customer, "Customer", "Покупатель")

System_Boundary(oms, "Order Management System") {
    Container(web_ui, "Web UI", "React", "Пользовательский интерфейс")
    Container(api_gateway, "API Gateway", "Go + Gin", "Единая точка входа")
    Container(order_service, "Order Service", "Go", "Управление заказами")
    Container(payment_service, "Payment Service", "Go", "Управление платежами")
    ContainerDb(postgres, "PostgreSQL", "Хранилище данных")
}

System_Ext(payment_gateway, "Payment Gateway", "Внешний платежный шлюз")
System_Ext(notification_service, "Notification Service", "Внешняя система уведомлений")

Rel(customer, web_ui, "Использует", "HTTPS")
Rel(web_ui, api_gateway, "Вызывает", "HTTPS")
Rel(api_gateway, order_service, "Маршрутизирует", "gRPC")
Rel(order_service, payment_service, "Вызывает", "gRPC")
Rel(order_service, postgres, "Читает/пишет", "SQL")
Rel(payment_service, postgres, "Читает/пишет", "SQL")
Rel(order_service, notification_service, "Отправляет уведомления", "SMTP/HTTP")
Rel(payment_service, payment_gateway, "Обрабатывает платежи", "HTTPS")
@enduml